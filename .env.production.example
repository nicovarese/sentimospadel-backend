SPRING_PROFILES_ACTIVE=production
DB_URL=jdbc:postgresql://<production-db-host>:5432/sentimospadel?currentSchema=public
DB_USERNAME=sentimospadel_user
DB_PASSWORD=<production-db-password>
JWT_SECRET=<long-random-production-jwt-secret>

EMAIL_VERIFICATION_LOG_ONLY=false
EMAIL_VERIFICATION_BASE_URL=https://api.sentimospadel.com/api/auth/verify-email
EMAIL_VERIFICATION_LOGIN_URL=https://sentimospadel.com
EMAIL_VERIFICATION_FROM=no-reply@sentimospadel.com

MAIL_HOST=<smtp-host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

MATCH_INVITATION_BASE_URL=https://sentimospadel.com
TOURNAMENT_INVITATION_BASE_URL=https://sentimospadel.com

PLAYER_PROFILE_PHOTO_STORAGE_PATH=/var/sentimospadel/player-profile-photos
PLAYER_PROFILE_PHOTO_PUBLIC_BASE_URL=https://api.sentimospadel.com/api/player-profile-photos

PUSH_NOTIFICATIONS_ENABLED=true
PUSH_NOTIFICATIONS_PROVIDER=fcm
PUSH_NOTIFICATIONS_LOG_PAYLOADS=false
FCM_PROJECT_ID=<firebase-project-id>
FCM_SERVICE_ACCOUNT_JSON_BASE64=<firebase-service-account-json-base64>
