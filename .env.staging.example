SPRING_PROFILES_ACTIVE=staging
DB_URL=jdbc:postgresql://<staging-db-host>:5432/sentimospadel_staging?currentSchema=public
DB_USERNAME=sentimospadel_staging_user
DB_PASSWORD=<staging-db-password>
JWT_SECRET=<long-random-staging-jwt-secret>

EMAIL_VERIFICATION_LOG_ONLY=false
EMAIL_VERIFICATION_BASE_URL=https://api-staging.sentimospadel.com/api/auth/verify-email
EMAIL_VERIFICATION_LOGIN_URL=https://staging.sentimospadel.com
EMAIL_VERIFICATION_FROM=no-reply@staging.sentimospadel.com

MAIL_HOST=<smtp-host>
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

MATCH_INVITATION_BASE_URL=https://staging.sentimospadel.com
TOURNAMENT_INVITATION_BASE_URL=https://staging.sentimospadel.com

PLAYER_PROFILE_PHOTO_STORAGE_PATH=/var/sentimospadel/player-profile-photos
PLAYER_PROFILE_PHOTO_PUBLIC_BASE_URL=https://api-staging.sentimospadel.com/api/player-profile-photos

PUSH_NOTIFICATIONS_PROVIDER=log-only
PUSH_NOTIFICATIONS_LOG_PAYLOADS=true
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON_BASE64=
